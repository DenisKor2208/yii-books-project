{
	// ==================================================
	// Настройки, перенесённые из глобальных для текущего проекта
	// ==================================================

	// --------------------------------------------------
	// 1. Шрифты и внешний вид редактора
	// --------------------------------------------------
	"editor.fontSize": 16, // Основной размер шрифта в редакторе
	"editor.fontFamily": "JetBrains Mono", // Шрифт редактора
	"editor.fontLigatures": true, // Включение лигатур (=>, !== и т.п.)
	"terminal.integrated.fontSize": 16, // Размер шрифта в терминале
	"terminal.integrated.fontFamily": "JetBrains Mono", // Шрифт в терминале
	"workbench.colorTheme": "Solarized Dark", // Цветовая тема

	// --------------------------------------------------
	// 2. Поведение редактора (форматирование, табы, перенос)
	// --------------------------------------------------
	"editor.tabSize": 2, // Размер табуляции (в пробелах)
	"editor.wordWrap": "on", // Перенос строк по ширине окна
	"editor.formatOnSave": true, // Автоформатирование при сохранении
	"editor.formatOnPaste": true, // Автоформатирование при вставке
	"editor.defaultFormatter": "esbenp.prettier-vscode", // Форматтер по умолчанию (Prettier)

	// --------------------------------------------------
	// 3. Настройки Prettier (форматирование кода)
	// --------------------------------------------------
	"prettier.useTabs": true, // Использовать табы вместо пробелов
	"prettier.semi": false, // Не добавлять точки с запятой в конце строк
	"prettier.jsxSingleQuote": true, // Использовать одинарные кавычки в JSX
	"prettier.singleQuote": true, // Использовать одинарные кавычки
	"prettier.arrowParens": "avoid", // Опускать скобки у стрелочных функций, где можно

	// --------------------------------------------------
	// 4. Терминал
	// --------------------------------------------------
	"terminal.integrated.defaultProfile.windows": "Command Prompt", // Профиль терминала по умолчанию (Windows)
	"terminal.integrated.smoothScrolling": true, // Плавная прокрутка в терминале
	"terminal.integrated.cursorBlinking": true, // Мигающий курсор в терминале

	// --------------------------------------------------
	// 5. Навигация (Breadcrumbs)
	// --------------------------------------------------
	// Полное отключение breadcrumbs (хлебных крошек) или отдельных элементов
	"breadcrumbs.icons": false,
	"breadcrumbs.showKeys": false,
	"breadcrumbs.showFiles": false,
	"breadcrumbs.symbolPath": "off",
	"breadcrumbs.showArrays": false,
	"breadcrumbs.showBooleans": false,
	"breadcrumbs.showClasses": false,
	"breadcrumbs.showConstants": false,
	"breadcrumbs.showConstructors": false,
	"breadcrumbs.showEnumMembers": false,
	"breadcrumbs.showEvents": false,
	"breadcrumbs.showFields": false,
	"breadcrumbs.showEnums": false,
	"breadcrumbs.showFunctions": false,
	"breadcrumbs.showInterfaces": false,
	"breadcrumbs.showMethods": false,
	"breadcrumbs.showModules": false,
	"breadcrumbs.showNamespaces": false,
	"breadcrumbs.showNull": false,
	"breadcrumbs.showNumbers": false,
	"breadcrumbs.showObjects": false,
	"breadcrumbs.showOperators": false,
	"breadcrumbs.showPackages": false,
	"breadcrumbs.showProperties": false,
	"breadcrumbs.showStrings": false,
	"breadcrumbs.showStructs": false,
	"breadcrumbs.showTypeParameters": false,
	"breadcrumbs.showVariables": false,

	// --------------------------------------------------
	// 6. Интерфейс (мини‑карта, плавность, отступы и пр.)
	// --------------------------------------------------
	"editor.minimap.renderCharacters": false, // Отключить рендеринг символов на мини‑карте
	"editor.minimap.enabled": false, // Полностью отключить мини‑карту
	"editor.smoothScrolling": true, // Плавная прокрутка в редакторе
	"workbench.list.smoothScrolling": true, // Плавная прокрутка в списках
	"editor.cursorBlinking": "expand", // Стиль мигания курсора (expand)
	"editor.glyphMargin": true, // Показывать поля для значков (точки останова и т.п.)
	"editor.linkedEditing": true, // Синхронное редактирование парных тегов (например, в HTML)
	"editor.padding.top": 15, // Верхний отступ в редакторе
	"explorer.compactFolders": false, // Отключить компактное отображение папок в проводнике
	"explorer.confirmDelete": false, // Не спрашивать подтверждение при удалении файлов
	"explorer.confirmDragAndDrop": false, // Не спрашивать подтверждение при перетаскивании

	// --------------------------------------------------
	// 8. Безопасность и доверие
	// --------------------------------------------------
	"security.workspace.trust.untrustedFiles": "open", // Поведение при открытии файлов из недоверенных папок
	"security.allowedUNCHosts": ["wsl.localhost"], // Разрешённые UNC‑хосты (для WSL)

	// --------------------------------------------------
	// 9. Отладка
	// --------------------------------------------------
	"debug.allowBreakpointsEverywhere": true, // Разрешить точки останова в любом месте (даже если код не выполняется)
	"debug.showBreakpointsInOverviewRuler": true, // Отображать точки останова на линейке обзора
	// "php.debug.executablePath": "C:/OSPanel/modules/php/PHP_8.1/php.exe", // Путь к PHP для отладчика

	// --------------------------------------------------
	// 10. Прочее
	// --------------------------------------------------
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"files.autoSave": "onFocusChange",

	// ОТКЛЮЧАЕМ ВСТРОЕННЫЕ МЕХАНИЗМЫ PHP (чтобы не конфликтовали с Intelephense)
	"php.suggest.basic": false,
	"php.validate.enable": false,

	// ОСНОВНЫЕ НАСТРОЙКИ INTELEPHENSE
	"intelephense.environment.phpVersion": "8.2.0", // Указываем версию PHP из контейнера
	"intelephense.environment.includePaths": ["${workspaceFolder}/vendor"],

	// НАСТРОЙКИ АВТОДОПОЛНЕНИЯ (на основе твоего скриншота)
	// Можно оставить true (по умолчанию) - это разрешает подсказывать статические методы через ->
	"intelephense.completion.suggestObjectOperatorStaticMethods": true,
	"[php]": {
		"editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
	},

	// ОПЦИОНАЛЬНО: если хочешь видеть подсказки для магических методов из @mixin (полезно для Laravel и сложных трейтов)
	// "intelephense.completion.triggerParameterHints": true,

	"database-client.connections": [
		{
			"name": "MySQL (yii1) из Docker",
			"host": "localhost",
			"port": 33061,
			"user": "root",
			"password": "secret",
			"database": "yii1",
			"ssl": false
		}
	]
}
